            "mainClass": "com.rishabh.taco_cloud.TacoCloudApplication",
            "projectName": "taco-cloud"
        },
        {
            "type": "java",
            "name": "SecurityApplication",
            "request": "launch",
            "mainClass": "com.rishabh.security.SecurityApplication",
            "projectName": "security"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "PractiseApplication",
            "request": "launch",
            "mainClass": "com.example.practise.PractiseApplication",
            "projectName": "practise"
        }
    ]
